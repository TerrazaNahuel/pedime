SECRET_KEY=generá una con: python -c "import secrets; print(secrets.token_hex(64))"
DATABASE_URL=postgresql://user:pass@host:5432/pedime
ENVIRONMENT=production
SITE_URL=https://pedime.ar

# Límites de planes
MAX_PRODUCTS_PER_CATEGORY=10   # Free: máx productos por categoría
MAX_CATEGORIES_FREE=5           # Free: máx categorías
MAX_CATEGORIES_VIP=15           # VIP Básico: máx categorías
MAX_REORDER_IDS=500
MAX_FILE_SIZE_MB=10

# Rate limits
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=60
REGISTER_MAX_ATTEMPTS=3
REGISTER_WINDOW_SECONDS=300
PASSWORD_CHANGE_MAX_ATTEMPTS=5
PASSWORD_CHANGE_WINDOW_SECONDS=60
SUPER_RESET_MAX_ATTEMPTS=3
SUPER_RESET_WINDOW_SECONDS=3600

# Mercado Pago (cuando tengas credenciales)
# MP_ACCESS_TOKEN=APP_USR-xxxxxxxx
# MP_WEBHOOK_SECRET=xxxxxxxx

# Precios VIP
# VIP_BASICO_PRICE=12999
# VIP_PREMIUM_PRICE=30000
# PREMIUM_DURATION_DAYS=30
